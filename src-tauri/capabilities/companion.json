{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "companion-capability",
  "description": "Capability for the companion window. Receives game-started/game-stopped/schema-resolved events; can show/hide/move/resize itself; supports custom drag region for borderless chrome (D-13).",
  "windows": ["companion"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "updater:default"
  ]
}
